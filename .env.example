# OpenAI
OPENAI_API_KEY=sk-...
# Model used for scanning and remediation (any chat-completions capable model)
SECAGENT_MODEL=gpt-4o

# GitHub personal access token with `repo` scope (contents + pull_requests: write)
GITHUB_TOKEN=ghp_...

# Optional defaults
# Comma-separated glob patterns to exclude from scanning
SECAGENT_EXCLUDE=**/node_modules/**,**/.git/**,**/dist/**,**/build/**,**/*.min.js,**/vendor/**
# Max file size to scan, in KB
SECAGENT_MAX_FILE_KB=200
# Minimum severity to auto-remediate: low | medium | high | critical
SECAGENT_MIN_FIX_SEVERITY=medium
